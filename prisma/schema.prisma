// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STUDENT
  INSTRUCTOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Admission {
  id        String   @id @default(cuid())
  fullName  String
  dob       String
  gender    String
  category  String
  mobile    String
  email     String
  address   String
  course    String
  hostel    String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  phone     String
  course    String
  message   String
  status    String   @default("Unread")
  createdAt DateTime @default(now())
}

model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  image       String?
  duration    String
  fees        Float
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HomePageContent {
  id              String   @id @default("1")
  heroBadge       String
  heroTitle       String
  heroSubtitle    String
  stats           Json     // Array of {label, value}
  featuresTitle   String
  featuresSub     String
  features        Json     // Array of {title, desc, iconName}
  coursesTitle    String
  coursesSub      String
  ctaTitle        String
  ctaSub          String
  updatedAt       DateTime @updatedAt
}

model Notice {
  id             String   @id @default(cuid())
  title          String
  targetAudience String
  date           String
  isPinned       Boolean  @default(false)
  status         String   @default("Draft")
  createdAt      DateTime @default(now())
}

model MockTest {
  id           String   @id @default(cuid())
  title        String
  course       String
  date         String
  participants Int      @default(0)
  status       String   @default("Scheduled")
  createdAt    DateTime @default(now())
}
