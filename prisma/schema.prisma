// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  INSTRUCTOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Admission {
  id        String   @id @default(cuid())
  fullName  String
  dob       String
  gender    String
  category  String
  mobile    String
  email     String
  address   String
  course    String
  hostel    String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  phone     String
  course    String
  message   String
  status    String   @default("Unread")
  createdAt DateTime @default(now())
}

model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  image       String?
  duration    String
  fees        Float
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
